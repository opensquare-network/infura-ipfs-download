INFURA_PROJECT_ID=your_project_id_here
INFURA_PROJECT_SECRET=your_project_secret_here
# Optional — used as the download folder name. Falls back to PROJECT_ID if not set.
INFURA_PROJECT_NAME=my-project
# Optional — number of concurrent downloads (default: 3)
CONCURRENCY=3
IPFS_ENDPOINT=https://ipfs.infura.io/ipfs

# Cloudflare R2 (S3-compatible) — for uploading downloaded files
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your-bucket-name
# Optional — public base URL for generating file links after upload
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
